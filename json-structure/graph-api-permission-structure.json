{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/microsoft-word/refs/heads/main/json-structure/graph-api-permission-structure.json",
  "name": "Permission",
  "description": "Represents a sharing permission on a drive item.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "description": "The unique identifier of the permission." },
    "roles": { "type": "array", "items": { "type": "string" }, "description": "The type of permission." },
    "link": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "The type of sharing link." },
        "webUrl": { "type": "uri", "description": "The URL of the sharing link." },
        "scope": { "type": "string", "description": "The scope of the link." }
      }
    }
  }
}
